# Voter — environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# ============================================================
# Required for the app to run
# ============================================================

# Supabase (anon key — used by client + server for RLS-protected reads)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Privacy-preserving identifier hashing — server-side HMAC key.
# 32+ random bytes. Used to hash IPs and user-agent strings for the
# consent_audit and session_visits tables. Without this, a leaked
# database would let attackers brute-force IP hashes (2^32 IPv4 keyspace
# computes in minutes on commodity GPUs).
# Generate: `openssl rand -hex 32` or `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`
# Rotate: monthly. Never log. Never return in responses.
# Required in production. Dev falls back to a fixed dev-only string with a console warning.
IP_HASH_SECRET=

# ============================================================
# LLM matching (Phase 2B)
# ============================================================

# Anthropic — used for both the live /api/match path and offline stance synthesis.
# Cheapest tier (Haiku 4.5) is sufficient for both.
# Without this, /api/match falls back to a deterministic local heuristic.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Kill switch for the LLM matcher. Set to "true" to disable Haiku calls
# (e.g., during a runaway-cost incident). Mock fallback still serves matches.
MATCH_API_DISABLED=

# ============================================================
# Data pipeline scripts (scripts/ingest/* and scripts/seed/*)
# Not used by the app at runtime. Only needed when curating new races.
# ============================================================

# Donor industries: FollowTheMoney (https://www.followthemoney.org/our-data/apis/).
# OpenSecrets retired their public API; FollowTheMoney is the closest free
# replacement and covers federal + state races (Governor candidates included).
# Free with email signup. Without it, donor profile falls back to raw FEC
# contributors without industry buckets.
FOLLOWTHEMONEY_API_KEY=

# Voting records: GovTrack (https://www.govtrack.us/developers/api).
# Keyless, actively maintained. Replaced ProPublica Congress (sunset 2023).
# No env var required — see src/lib/api-clients/govtrack.ts.

# FEC.gov — raw filings, fundraising totals (source of truth).
# https://api.data.gov/signup/
FEC_API_KEY=

# Supabase service role — used ONLY by seed scripts. Bypasses RLS.
# DO NOT commit, DO NOT expose to client.
SUPABASE_SERVICE_ROLE_KEY=
